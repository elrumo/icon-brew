# --- Nuxt app ---
NUXT_CLARITY_ID=""

# --- Parse Server (self-hosted, see docker-compose.yml) ---
# App-facing values consumed by the Nuxt client/server (baked into the client bundle at build time).
VITE_PARSE_APP_ID="iconbrew"
VITE_PARSE_KEY="change-me-client-key"
# External URL that Dokploy/Traefik routes to the parse-server service, including the mount path.
VITE_PARSE_SERVER_URL="https://parse.yourdomain.com/parse"

# Values consumed directly by the parse-server container (parse/index.js).
PARSE_APP_ID="iconbrew"
PARSE_MASTER_KEY="change-me-master-key"
PARSE_CLIENT_KEY="change-me-client-key"
# Internal URL (used by Parse Server itself); publicServerURL should be the external domain.
PARSE_SERVER_URL="http://parse-server:1337/parse"
PARSE_PUBLIC_URL="https://parse.yourdomain.com/parse"
PARSE_MOUNT_PATH="/parse"

# --- MongoDB (internal only, not exposed externally) ---
# No externally-facing config needed; parse-server connects via mongodb://mongo:27017/parse

# --- MeiliSearch (self-hosted, replaces Algolia) ---
MEILI_MASTER_KEY="change-me-meili-master-key"
# Internal URL used by the Nuxt server's /api/search route.
MEILI_URL="http://meilisearch:7700"
MEILI_INDEX="icons"

# --- S3-compatible storage for Parse Files (external Minio instance) ---
S3_ACCESS_KEY="change-me"
S3_SECRET_KEY="change-me"
S3_BUCKET="iconbrew"
S3_REGION="us-east-1"
S3_BUCKET_PREFIX=""
S3_ENDPOINT="https://minio.yourdomain.com"
# Public base URL used to build direct file links (often same host as S3_ENDPOINT, may differ
# if Minio sits behind a different public hostname/proxy than its API endpoint).
S3_BASE_URL="https://minio.yourdomain.com/iconbrew"
